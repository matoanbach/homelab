[all:vars]
ansible_connection=ssh
ansible_ssh_common_args='-o ControlMaster=no -o ControlPath=none -o StrictHostKeyChecking=no'


[test]
test1 ansible_host=remote_host ansible_user=remote_user ansible_private_key_file=/var/jenkins_home/ansible/remote-key host_key_checking=False
web1 ansible_host=web ansible_user=remote_user ansible_private_key_file=/var/jenkins_home/ansible/remote-key host_key_checking=False
